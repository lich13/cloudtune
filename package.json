{
  "name": "cloudtune",
  "productName": "CloudTune",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run tauri:dev",
    "dev:renderer": "vite",
    "build": "tsc -b && npm run build:renderer",
    "build:renderer": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "bash ./scripts/build-mac-dmg-with-fix.sh aarch64-apple-darwin",
    "tauri:build:mac:arm64": "bash ./scripts/build-mac-dmg-with-fix.sh aarch64-apple-darwin",
    "tauri:build:mac:arm64:app": "npm exec tauri build -- --target aarch64-apple-darwin --bundles app",
    "tauri:build:win:x64": "tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:win:arm64": "tauri build --target aarch64-pc-windows-msvc"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
